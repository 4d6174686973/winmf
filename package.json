{
  "name": "winmf",
  "type": "module",
  "author": "Mathis Makarski",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true pnpm build",
    "build": "next build",
    "clean": "rimraf .next .turbo",
    "debug": "NODE_OPTIONS='--inspect' next dev",
    "dev": "next",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "start": "next start -p $PORT"
  },
  "dependencies": {
    "aws-amplify": "^6.16.2",
    "markdown-to-jsx": "^6.11.4",
    "next": "^15.0.0",
    "nextra": "^4.0.0",
    "nextra-theme-docs": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-intersection-observer": "^8.34.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.21.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@next/bundle-analyzer": "^15.0.0",
    "@types/node": "22.5.4",
    "@types/react": "19.2.14",
    "@tailwindcss/postcss": "^4.0.0",
    "aws-cdk-lib": "^2.238.0",
    "constructs": "^10.4.5",
    "esbuild": "^0.25.12",
    "pagefind": "^1.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "esbuild",
      "sharp"
    ]
  },
  "nextBundleAnalysis": {
    "budget": 358400,
    "budgetPercentIncreaseRed": 20,
    "showDetails": true
  }
}
